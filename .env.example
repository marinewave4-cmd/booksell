# =====================================================
# 북셀 환경변수 설정 템플릿
# .env.local 파일로 복사하여 사용하세요
# =====================================================

# 사이트 URL (배포 후 실제 도메인으로 변경)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =====================================================
# Supabase 설정
# https://app.supabase.com 에서 프로젝트 생성 후 확인
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================
# 토스페이먼츠 결제 연동
# https://developers.tosspayments.com 에서 발급
# =====================================================
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# =====================================================
# 소셜 로그인 (선택사항)
# =====================================================

# 카카오 로그인
# https://developers.kakao.com 에서 앱 생성 후 발급
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Google 로그인
# https://console.cloud.google.com 에서 OAuth 2.0 클라이언트 ID 생성
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =====================================================
# 기타 설정
# =====================================================

# 운영 환경 설정 (development | production)
NODE_ENV=development

# =====================================================
# 북셀 환경변수 설정 템플릿
# .env.local 파일로 복사하여 사용하세요
# =====================================================

# 사이트 URL (배포 후 실제 도메인으로 변경)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =====================================================
# Supabase 설정
# https://app.supabase.com 에서 프로젝트 생성 후 확인
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================
# 토스페이먼츠 결제 연동 (국내 결제)
# https://developers.tosspayments.com 에서 발급
# =====================================================
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# =====================================================
# PayPal 결제 연동 (해외 결제)
# https://developer.paypal.com 에서 앱 생성 후 발급
# =====================================================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# =====================================================
# Google Analytics
# https://analytics.google.com 에서 측정 ID 발급
# =====================================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# =====================================================
# 소셜 로그인 (선택사항)
# Supabase Dashboard > Authentication > Providers 에서 설정
# =====================================================

# 카카오 로그인
# https://developers.kakao.com 에서 앱 생성 후 발급
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Google 로그인
# https://console.cloud.google.com 에서 OAuth 2.0 클라이언트 ID 생성
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 네이버 로그인
# https://developers.naver.com 에서 앱 등록 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Apple 로그인 (연 $99 필요)
# https://developer.apple.com 에서 설정
# Supabase Dashboard에서 Apple provider 설정 필요

# =====================================================
# 검색엔진 인증 (선택)
# =====================================================
# Google Search Console: https://search.google.com/search-console
# 네이버 서치어드바이저: https://searchadvisor.naver.com

# =====================================================
# 기타 설정
# =====================================================

# 운영 환경 설정 (development | production)
NODE_ENV=development
